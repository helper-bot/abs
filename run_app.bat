@echo off
title تشغيل الحقيبة التفاعلية محلياً
chcp 65001 > nul
clear
echo ===================================================
echo     تشغيل الحقيبة التفاعلية محلياً على جهازك
echo ===================================================
echo.
echo [1/3] التحقق من وجود Node.js...
where node >nul 2>nul
if %errorlevel% neq 0 (
    echo [!] لم يتم العثور على Node.js على جهازك.
    echo يرجى تحميل وتثبيت برنامج Node.js أولاً (إصدار LTS الموصى به) من الرابط التالي:
    echo https://nodejs.org
    echo.
    echo بعد تثبيت Node.js، قم بإغلاق هذه النافذة وافتحها مرة أخرى.
    pause
    exit
)

echo [2/3] تثبيت المكتبات المطلوبة لتشغيل العرض (يحدث هذا في المرة الأولى فقط)...
call npm install

echo [3/3] تشغيل التطبيق الآن...
echo سيتم فتح العرض التفاعلي تلقائياً في المتصفح الخاص بك.
echo.
echo لإنهاء العرض، قم بإغلاق هذه النافذة السوداء.
echo.

:: انتظر ثانيتين ثم افتح المتصفح على العنوان المحلي
timeout /t 2 >nul
start http://localhost:3000

:: ابدأ خادم التطبيق المحلي
call npm run dev
pause
